# ─────────────────────────────────────────────────────────
# AutomotiveOS Cloud ERP — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your production values.
# NEVER commit .env to version control.
#
# Documentación completa: docs/PROVISIONING.md (próximamente)

# ─── Server ─────────────────────────────────────────────
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"          # development | production | test

# ─── Database (Neon / Supabase Serverless PostgreSQL) ──
# Pooler connection string. Pool max=5, lazy connect.
# Ej: postgresql://user:pass@ep-example-123456.us-east-2.aws.neon.tech/automotive_os?sslmode=require
DATABASE_URL=""

# ─── Supabase (Auth / Storage / Realtime) ───────────────
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_PUBLISHABLE_KEY="[anon_key]"
SUPABASE_SERVICE_ROLE_KEY="[service_role_key]"

# ─── Multi-Tenant ──────────────────────────────────────
TENANT_SCHEMA_PREFIX="tenant_"

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL="info"                 # trace | debug | info | warn | error | fatal

# ─── Offline-First (Sync) ──────────────────────────────
SYNC_INTERVAL_MS=30000

# ─── SIFEN / DNIT — Facturación Electrónica (Paraguay) ─
# Ruta absoluta al certificado PKCS#12 (.p12) emitido por la DNIT
SIFEN_CERT_PATH="/etc/sifen/certificados/taller_jara.p12"
# Contraseña del archivo .p12
SIFEN_CERT_PASS=""
# Entorno operativo: HOMOLOGACION (pruebas) | PRODUCCION
SIFEN_ENV="HOMOLOGACION"
# URLs personalizadas (opcionales — por defecto usa endpoints oficiales DNIT)
# SIFEN_PROD_URL="https://sifen.dnit.gov.py/sifen-ws"
# SIFEN_TEST_URL="https://sifen-test.dnit.gov.py/sifen-ws"

# ─── Thinkcar — Importación Automática de Diagnósticos ─
# Cuenta Gmail para capturar adjuntos de tabletas Thinkcar
THINKCAR_EMAIL_USER="jarabrothersgroup@gmail.com"
# Contraseña de aplicación de 16 caracteres (no la contraseña regular)
THINKCAR_EMAIL_PASSWORD=""
# Correo que recibe alertas cuando un reporte no se vincula automáticamente
THINKCAR_ALERT_RECIPIENT="recepcion@tallerjara.com"
# THINKCAR_EMAIL_HOST="imap.gmail.com"
# THINKCAR_EMAIL_PORT=993
# THINKCAR_EMAIL_INTERVAL=300000     # Polling en ms
# THINKCAR_EMAIL_WATCH="true"
# THINKCAR_USB_WATCH="true"
# THINKCAR_USB_INTERVAL=60000
# THINKCAR_BT_WATCH="false"

# ─── RAG / Manual de Taller (OpenAI Embeddings) ────────
# Necesario para búsqueda semántica vectorial sobre manuales.
# Si no se configura, fallback a búsqueda ILIKE (offline-safe).
OPENAI_API_KEY=""
