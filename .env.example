# ──────────────────────────────────────────────
# AutomotiveOS Cloud ERP — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Database (Neon/Supabase PostgreSQL) ─────
# Connection string: postgres://user:pass@host:5432/db?sslmode=require
DATABASE_URL="postgres://user:password@host.neon.tech:5432/dbname?sslmode=require"

# ─── Server ───────────────────────────────────
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"

# ─── Multi-Tenant ─────────────────────────────
# Default schema prefix for tenant isolation
TENANT_SCHEMA_PREFIX="tenant_"

# ─── Offline-First (Sync) ─────────────────────
# Interval in ms for background sync when online
SYNC_INTERVAL_MS=30000

# ─── Logging ──────────────────────────────────
LOG_LEVEL="info"
