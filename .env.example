# ─────────────────────────────────────────────────────────
# AutomotiveOS Cloud ERP — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your production values.
# NEVER commit .env to version control.
#
# Uso con Docker:
#   cp .env.example .env
#   docker compose -f docker-compose.onpremise.yml up -d

# ─── Server ─────────────────────────────────────────────
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"          # development | production | test

# ─── Database (PostgreSQL Local) ────────────────────────
DATABASE_URL="postgresql://erp_user:erp_dev_password@localhost:5432/automotive_os?sslmode=disable"

# ─── Local Filesystem Storage ───────────────────────────
# Ruta donde se almacenan archivos subidos (fotos DVI, etc.)
STORAGE_PATH="/data/erp-storage"

# ─── JWT Authentication ────────────────────────────────
# Secreto para firmar tokens JWT — CAMBIAR EN PRODUCCIÓN
JWT_SECRET="change-me-in-production"

# ─── Multi-Tenant ──────────────────────────────────────
TENANT_SCHEMA_PREFIX="tenant_"

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL="info"                 # trace | debug | info | warn | error | fatal

# ─── Offline-First (Sync) ──────────────────────────────
SYNC_INTERVAL_MS=30000

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3000"

# ─── SIFEN / DNIT — Facturación Electrónica (Paraguay) ─
SIFEN_CERT_PATH=""
SIFEN_CERT_PASS=""
SIFEN_USE_TEST=true

# ─── RAG / OpenAI (Embeddings) ────────────────────────
OPENAI_API_KEY=""

# ─── WhatsApp / Evolution API ──────────────────────────
# URL del servidor Evolution API (Docker: http://evolution-api:8080)
WHATSAPP_API_URL="http://localhost:8080"
# API Key para autenticación con Evolution API
WHATSAPP_API_KEY="evolution-dev-api-key-change-me"

# ─── Twenty CRM ────────────────────────────────────────
# URL del servidor Twenty CRM (Docker: http://twenty-crm:3000)
TWENTY_API_URL="http://localhost:3001"
# API Key de Twenty CRM (Settings → API Keys en Twenty)
TWENTY_API_KEY=""
# GraphQL endpoint (opcional, por defecto /graphql)
TWENTY_GRAPHQL_URL="http://localhost:3001/graphql"

# ─── Docker Compose — PostgreSQL ───────────────────────
POSTGRES_PORT=5432
POSTGRES_DB="automotive_os"
POSTGRES_USER="erp_user"
POSTGRES_PASSWORD="erp_dev_password"

# ─── Docker Compose — Redis ────────────────────────────
REDIS_PORT=6379
REDIS_URL="redis://redis:6379"
REDIS_PASSWORD="erp_redis_dev_password"

# ─── Docker Compose — Twenty CRM ──────────────────────
TWENTY_PORT=3001
TWENTY_DB="twenty_crm"
TWENTY_SERVER_URL="http://localhost:3001"
TWENTY_FRONT_BASE_URL="http://localhost:3001"
TWENTY_ACCESS_TOKEN_SECRET="twenty-dev-access-secret-change-me"
TWENTY_LOGIN_TOKEN_SECRET="twenty-dev-login-secret-change-me"
TWENTY_REFRESH_TOKEN_SECRET="twenty-dev-refresh-secret-change-me"
TWENTY_FILE_TOKEN_SECRET="twenty-dev-file-secret-change-me"

# ─── Docker Compose — Evolution API ────────────────────
EVOLUTION_API_PORT=8080
EVOLUTION_DB="evolution_api"
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_WEBHOOK_URL="http://erp:3000/api/v1/whatsapp/webhook"
EVOLUTION_VERIFY_TOKEN=""
