{
  "name": "automotiveos-cloud-erp",
  "version": "0.1.0",
  "description": "AutomotiveOS Cloud ERP — Multi-Tenant B2B SaaS for automotive workshops (Paraguay), Fastify + TypeScript + Neon/Supabase",
  "type": "module",
  "main": "dist/app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "predev": "node -e \"process.env.DATABASE_URL||require('fs').existsSync('.env')?0:(console.error('\\n  [FALTA] Copiá .env.example a .env y completá las variables\\n'),process.exit(1))\"",
    "prestart": "node -e \"process.env.DATABASE_URL||require('fs').existsSync('.env')?0:(console.error('\\n  [FALTA] Copiá .env.example a .env y completá las variables\\n'),process.exit(1))\"",
    "start": "npm run start:dev",
    "start:dev": "tsx src/app.ts",
    "dev": "tsx watch src/app.ts",
    "build:css": "tailwindcss -i src/shared/public/css/tailwind-input.css -o src/shared/public/css/tailwind.min.css --minify",
    "typecheck": "tsc --noEmit",
    "build": "tsc && cp src/modules/intelligence/visual/tv-template.html dist/modules/intelligence/visual/ && rm -rf dist/shared/public && cp -r src/shared/public dist/shared/public",
    "start:prod": "node --max-old-space-size=48 --optimize-for-size --gc-interval=100 --expose-gc dist/app.js",
    "start:docker": "node --expose-gc --max-old-space-size=48 --optimize-for-size --gc-interval=100 dist/app.js",
    "db:migrate": "tsx src/shared/database/migrate.ts",
    "db:validate": "tsx src/shared/database/validate.ts",
    "db:smoke": "tsx src/shared/database/smoke-test.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "erp",
    "automotive",
    "paraguay",
    "sifen",
    "multi-tenant",
    "fastify"
  ],
  "author": "AutomotiveOS",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "@supabase/supabase-js": "^2.107.0",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "exif-be-gone": "^1.5.1",
    "fast-xml-parser": "^5.8.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "imapflow": "^1.3.7",
    "nodemailer": "^8.0.10",
    "pdf-parse": "^1.1.1",
    "postgres": "^3.4.9",
    "puppeteer-core": "^25.1.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
